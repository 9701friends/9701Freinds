### 로그인 MASTER
POST http://localhost:8080/users/login
Content-Type: application/json

{
  "email" : "hong@example.com",
  "password" : "1234"
}
> {%
var cookieHeader = response.headers.valueOf("Set-Cookie");
// 1. "Authorization=" 제거
var authValue = cookieHeader.split("=")[1];

// 2. "; Path=/" 이후 문자열 제거
authValue = authValue.split(";")[0];

// 3. URL 디코딩 (Bearer%20 → Bearer )
authValue = decodeURIComponent(authValue);
client.log("정리된 토큰 : " + authValue);
  client.global.set("master_cookie", authValue);
 %}

### 로그인 MANAGER
POST http://localhost:8080/users/login
Content-Type: application/json
Cookies: ignore

{
  "email" : "french@paris.com",
  "password" : "1234"
}
> {%
  var cookieHeader = response.headers.valueOf("Set-Cookie");
  // 1. "Authorization=" 제거
  var authValue = cookieHeader.split("=")[1];

  // 2. "; Path=/" 이후 문자열 제거
  authValue = authValue.split(";")[0];

  // 3. URL 디코딩 (Bearer%20 → Bearer )
  authValue = decodeURIComponent(authValue);
  client.log("정리된 토큰 : " + authValue);
  client.global.set("manager_cookie", authValue);
%}


