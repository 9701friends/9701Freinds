### 로그인 CUSTOMER
POST http://localhost:8080/users/login
Content-Type: application/json
Cookies: ignore

{
  "email" : "go@example.com",
  "password" : "1234"
}
> {%
  var cookieHeader = response.headers.valueOf("Set-Cookie");
  // 1. "Authorization=" 제거
  var authValue = cookieHeader.split("=")[1];

  // 2. "; Path=/" 이후 문자열 제거
  authValue = authValue.split(";")[0];

  // 3. URL 디코딩 (Bearer%20 → Bearer )
  authValue = decodeURIComponent(authValue);
  client.log("정리된 토큰 : " + authValue);
  client.global.set("customer_cookie", authValue);
%}

### 여기까지 더미 회원 데이터


### 사용자 정보 수정
PUT http://localhost:8080/users/1
Content-Type: application/json
Authorization: {{master_cookie}}

{
  "name": "제라드변신",
  "email": "steven@thefootball.com",
  "nickname": "HeartOfLiverpool",
  "password": "1234",
  "role": "OWNER",
  "phone": "01079794242",
  "address": "여기 내 마음속"
}

### 사용자 삭제
DELETE http://localhost:8080/users/1
Content-Type: application/json
Authorization: {{master_cookie}}

{
  "password": "1234"
}

### 특정 사용자 조회 (관리자 권한 필요)
GET http://localhost:8080/users/1
Authorization: {{master_cookie}}

